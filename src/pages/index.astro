---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allCases = await getCollection('cases');

// Фільтрація
const exportCases = allCases.filter(c => c.data.market === 'export');
const ukraineCases = allCases.filter(c => c.data.market === 'ukraine');

const caseHref = (slug: string) => `${base}/cases/${slug}/`;
---

<Layout title="Maksym Scale | External Growth Partner для виробництв">

  <nav class="fixed top-0 left-0 right-0 z-50 glass border-b border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 sm:h-20">
        <a href="#" class="flex items-center gap-2 group">
          <div class="w-8 h-8 sm:w-10 sm:h-10 bg-white rounded-lg flex items-center justify-center group-hover:scale-105 transition-transform">
            <span class="text-black font-bold text-sm sm:text-lg">MS</span>
          </div>
          <span class="text-white font-semibold text-sm sm:text-base tracking-tight">Maksym<span class="text-white/50">.scale</span></span>
        </a>
        <a href="https://t.me/Mak_sy_ym" target="_blank" class="inline-flex items-center gap-2 px-6 py-2.5 bg-white text-black text-sm font-semibold rounded-full hover:bg-white/90 transition-all hover:scale-105 active:scale-95">
          Зв'язатися <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <section class="relative min-h-screen flex items-center justify-center pt-20 pb-16 px-4 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot; fill=&quot;%23ffffff&quot;/%3E%3C/svg%3E');"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-white/[0.02] rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full border border-white/10 bg-white/[0.03] text-sm text-white/60">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span> Приймаю нових клієнтів
      </div>
      <h1 class="text-5xl sm:text-7xl font-bold tracking-tight mb-8">
        <span class="gradient-text">Maksym Scale</span><br />
        <span class="text-white/40 text-3xl sm:text-5xl font-medium">External Growth Partner</span>
      </h1>
      <p class="text-lg sm:text-xl text-white/50 max-w-2xl mx-auto mb-12 font-light leading-relaxed">
        Будую керовані системи продажів, які генерують стабільний кешфлоу. <span class="text-white/70 font-normal">Не просто налаштовую таргет — беру відповідальність за результат.</span>
      </p>
      
      <div class="flex flex-wrap justify-center gap-10 mb-16">
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-bold text-white">$2M<span class="text-white/30">+</span></div>
          <div class="text-xs text-white/40 mt-1 uppercase tracking-widest">Згенеровано</div>
        </div>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-bold text-white">12.75<span class="text-white/30">x</span></div>
          <div class="text-xs text-white/40 mt-1 uppercase tracking-widest">ROAS</div>
        </div>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-bold text-white">3<span class="text-white/30">+</span></div>
          <div class="text-xs text-white/40 mt-1 uppercase tracking-widest">Роки досвіду</div>
        </div>
      </div>
    </div>
  </section>

  <section id="cases" class="py-24 px-4 sm:px-6" x-data="{ market: 'export' }">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-5xl font-bold tracking-tight gradient-text">Де ви хочете масштабувати продукт?</h2>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 max-w-2xl mx-auto mb-16">
        <button @click="market = 'export'" :class="market === 'export' ? 'border-white/30 bg-white/[0.08] text-white' : 'text-white/40'" class="flex-1 px-8 py-5 rounded-2xl border border-white/10 bg-white/[0.03] transition-all text-center group">
          <span class="text-2xl block mb-1">🌍</span> Ринок США та ЄС
        </button>
        <button @click="market = 'ukraine'" :class="market === 'ukraine' ? 'border-white/30 bg-white/[0.08] text-white' : 'text-white/40'" class="flex-1 px-8 py-5 rounded-2xl border border-white/10 bg-white/[0.03] transition-all text-center group">
          <span class="text-2xl block mb-1">🇺🇦</span> Ринок України
        </button>
      </div>

      <div x-show="market === 'export'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" class="space-y-6">
        {exportCases.map((item) => (
          <a href={caseHref(item.slug)} class="glass rounded-[2.5rem] p-8 sm:p-10 block hover:border-white/20 transition-all group">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
              <div class="flex-1">
                <div class="flex gap-2 mb-6">
                  <span class="px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-bold border border-emerald-500/20 uppercase tracking-widest">Кейс</span>
                  <span class="px-3 py-1 rounded-full bg-white/5 text-white/40 text-[10px] uppercase tracking-widest">Експорт</span>
                </div>
                <h3 class="text-2xl sm:text-3xl font-bold text-white group-hover:text-emerald-400 transition-colors leading-tight">{item.data.title}</h3>
                <p class="mt-4 text-white/40 leading-relaxed max-w-2xl">{item.data.excerpt}</p>
              </div>
              <div class="flex gap-4 sm:gap-6">
                <div class="glass px-6 py-4 rounded-2xl text-center min-w-[130px]">
                  <div class="text-2xl font-bold text-white">{item.data.result}</div>
                  <div class="text-[10px] text-white/30 uppercase tracking-widest mt-1">Результат</div>
                </div>
                <div class="glass px-6 py-4 rounded-2xl text-center min-w-[130px]">
                  <div class="text-2xl font-bold text-emerald-400">{item.data.roas}</div>
                  <div class="text-[10px] text-white/30 uppercase tracking-widest mt-1">ROAS</div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div x-show="market === 'ukraine'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" class="space-y-6">
        {ukraineCases.map((item) => (
          <a href={caseHref(item.slug)} class="glass rounded-[2.5rem] p-8 sm:p-10 block hover:border-white/20 transition-all group">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
              <div class="flex-1">
                <div class="flex gap-2 mb-6">
                  <span class="px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 text-[10px] font-bold border border-blue-500/20 uppercase tracking-widest">Кейс</span>
                  <span class="px-3 py-1 rounded-full bg-white/5 text-white/40 text-[10px] uppercase tracking-widest">Україна</span>
                </div>
                <h3 class="text-2xl sm:text-3xl font-bold text-white group-hover:text-blue-400 transition-colors leading-tight">{item.data.title}</h3>
                <p class="mt-4 text-white/40 leading-relaxed max-w-2xl">{item.data.excerpt}</p>
              </div>
              <div class="flex gap-4 sm:gap-6">
                <div class="glass px-6 py-4 rounded-2xl text-center min-w-[130px]">
                  <div class="text-2xl font-bold text-white">{item.data.result}</div>
                  <div class="text-[10px] text-white/30 uppercase tracking-widest mt-1">Результат</div>
                </div>
                <div class="glass px-6 py-4 rounded-2xl text-center min-w-[130px]">
                  <div class="text-2xl font-bold text-blue-400">{item.data.roas}</div>
                  <div class="text-[10px] text-white/30 uppercase tracking-widest mt-1">ROAS</div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-4 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-8">
      <div class="glass rounded-[2.5rem] p-10 border-red-500/10">
        <h3 class="text-2xl font-bold text-white/40 mb-8">🔴 Таргетолог</h3>
        <ul class="space-y-4 text-white/40 text-sm">
          <li>✕ Відповідає тільки за ліди</li>
          <li>✕ Не рахує юніт-економіку</li>
          <li>✕ Ігнорує маржинальність бізнесу</li>
        </ul>
      </div>
      <div class="glass rounded-[2.5rem] p-10 border-emerald-500/20">
        <h3 class="text-2xl font-bold text-white mb-8">🟢 Growth Partner</h3>
        <ul class="space-y-4 text-white text-sm">
          <li>✓ Рахую Unit-економіку перед запуском</li>
          <li>✓ Оптимізую шлях клієнта до покупки</li>
          <li>✓ Відповідаю за кінцевий прибуток</li>
        </ul>
      </div>
    </div>
  </section>

</Layout>

<script is:inline src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
