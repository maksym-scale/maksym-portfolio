---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allCases = await getCollection('cases');

const exportCases = allCases.filter(c => c.data.market === 'export');
const ukraineCases = allCases.filter(c => c.data.market === 'ukraine');

const caseHref = (slug: string) => `${base}/cases/${slug}/`;
---

<Layout title="Maksym Scale — Growth Partner">
  <main class="bg-[#0a0a0a] min-h-screen text-white">
    
    <section class="pt-32 pb-20 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(16,185,129,0.05),transparent_50%)]"></div>
        <h1 class="relative text-6xl font-bold tracking-tight sm:text-8xl bg-gradient-to-b from-white to-white/60 bg-clip-text text-transparent">
          Maksym Scale
        </h1>
        <p class="relative mt-8 text-xl text-white/50 max-w-2xl mx-auto">
          Growth Partner для вашого eCommerce бізнесу.
        </p>
    </section>

    <section class="py-20 mx-auto max-w-6xl px-6" x-data="{ market: 'export' }">
      <div class="flex justify-center mb-16">
        <div class="inline-flex p-1 bg-white/5 border border-white/10 rounded-2xl">
          <button @click="market = 'export'" :class="market === 'export' ? 'bg-emerald-500 text-black' : 'text-white/60'" class="px-8 py-3 rounded-xl text-sm font-bold transition-all">
            США та ЄС
          </button>
          <button @click="market = 'ukraine'" :class="market === 'ukraine' ? 'bg-emerald-500 text-black' : 'text-white/60'" class="px-8 py-3 rounded-xl text-sm font-bold transition-all">
            Україна
          </button>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <template x-if="market === 'export'">
          {exportCases.map(item => (
            <a href={caseHref(item.slug)} class="group block rounded-[2.5rem] border border-white/5 bg-white/[0.02] p-10 hover:border-emerald-500/30 transition-all">
              <div class="flex justify-between items-start mb-8">
                <span class="px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-[10px] uppercase text-emerald-400 font-bold">Кейс: Експорт</span>
                <div class="text-right">
                    <div class="text-2xl font-bold text-white">{item.data.result}</div>
                    <div class="text-[10px] text-white/30 uppercase">Виручка</div>
                </div>
              </div>
              <h3 class="text-3xl font-bold text-white group-hover:text-emerald-400 transition-colors leading-tight">{item.data.title}</h3>
              <p class="mt-6 text-white/50 line-clamp-2">{item.data.excerpt}</p>
              <div class="mt-10 pt-10 border-t border-white/5 flex gap-10">
                 <div><span class="block text-white/30 text-[10px] uppercase mb-1">ROAS</span><span class="text-white font-medium">{item.data.roas}</span></div>
                 <div class="ml-auto flex items-center gap-2 text-sm text-white/80">Читати кейс <span>→</span></div>
              </div>
            </a>
          ))}
        </template>

        <template x-if="market === 'ukraine'">
          {ukraineCases.map(item => (
            <a href={caseHref(item.slug)} class="group block rounded-[2.5rem] border border-white/5 bg-white/[0.02] p-10 hover:border-emerald-500/30 transition-all">
              <div class="flex justify-between items-start mb-8">
                <span class="px-3 py-1 rounded-full border border-white/5 bg-white/5 text-[10px] uppercase text-white/40 font-bold">Кейс: Україна</span>
                <div class="text-right">
                    <div class="text-2xl font-bold text-white">{item.data.result}</div>
                    <div class="text-[10px] text-white/30 uppercase">Результат</div>
                </div>
              </div>
              <h3 class="text-3xl font-bold text-white group-hover:text-emerald-400 transition-colors leading-tight">{item.data.title}</h3>
              <p class="mt-6 text-white/50 line-clamp-2">{item.data.excerpt}</p>
              <div class="mt-10 pt-10 border-t border-white/5 flex gap-10">
                 <div><span class="block text-white/30 text-[10px] uppercase mb-1">ROAS</span><span class="text-white font-medium">{item.data.roas}</span></div>
                 <div class="ml-auto flex items-center gap-2 text-sm text-white/80">Читати кейс <span>→</span></div>
              </div>
            </a>
          ))}
        </template>
      </div>
    </section>
  </main>
</Layout>

<script is:inline src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
