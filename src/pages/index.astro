  <!-- TAB SWITCHING SCRIPT -->
  <!-- ═══════════════════════════════════════ -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.tab-btn');
      const exportContent = document.getElementById('content-export');
      const ukraineContent = document.getElementById('content-ukraine');

      function switchTab(target: string) {
        tabs.forEach(tab => {
          if (tab.getAttribute('data-tab') === target) {
            tab.classList.add('active');
            tab.classList.add('!border-white/30', '!bg-white/[0.08]', '!text-white');
          } else {
            tab.classList.remove('active');
            tab.classList.remove('!border-white/30', '!bg-white/[0.08]', '!text-white');
          }
        });

        if (target === 'export') {
          exportContent?.classList.remove('hidden-tab');
          exportContent?.classList.add('active-tab');
          ukraineContent?.classList.add('hidden-tab');
          ukraineContent?.classList.remove('active-tab');
        } else {
          ukraineContent?.classList.remove('hidden-tab');
          ukraineContent?.classList.add('active-tab');
          exportContent?.classList.add('hidden-tab');
          exportContent?.classList.remove('active-tab');
        }

        // Re-trigger reveal animations for the new content
        const newContent = target === 'export' ? exportContent : ukraineContent;
        newContent?.querySelectorAll('.reveal').forEach(el => {
          el.classList.remove('visible');
          setTimeout(() => el.classList.add('visible'), 50);
        });
      }

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');
          if (target) switchTab(target);
        });
      });

      // Initialize first tab as active
      switchTab('export');
    });
  </script>

