---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <article class="bg-[#0a0a0a] min-h-screen text-white py-32">
    <div class="max-w-3xl mx-auto px-6">
      <a href="/maksym-portfolio/#cases" class="text-emerald-400 text-sm hover:underline">← Назад до кейсів</a>
      
      <header class="mt-12 mb-20">
        <h1 class="text-5xl font-bold mb-8">{entry.data.title}</h1>
        <div class="grid grid-cols-2 gap-8 p-8 rounded-3xl border border-white/5 bg-white/[0.02]">
            <div>
                <div class="text-white/30 text-[10px] uppercase">Результат</div>
                <div class="text-3xl font-bold text-emerald-400">{entry.data.result}</div>
            </div>
            <div>
                <div class="text-white/30 text-[10px] uppercase">ROAS</div>
                <div class="text-3xl font-bold text-white">{entry.data.roas}</div>
            </div>
        </div>
      </header>

      <div class="prose prose-invert prose-emerald max-w-none prose-img:rounded-3xl">
        <Content />
      </div>
    </div>
  </article>
</Layout>