---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <main class="bg-[#0a0a0a] min-h-screen text-white pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-6">
      <a href="/maksym-portfolio/#cases" class="text-emerald-400 text-sm hover:text-emerald-300 transition-colors">← Назад до кейсів</a>
      
      <header class="mt-12 mb-16">
        <h1 class="text-4xl font-bold sm:text-6xl mb-8 leading-tight">{entry.data.title}</h1>
        <div class="grid grid-cols-2 gap-6 p-8 rounded-3xl border border-white/5 bg-white/[0.02] backdrop-blur-sm">
            <div>
                <div class="text-white/30 text-[10px] uppercase tracking-widest mb-1">Результат</div>
                <div class="text-3xl font-bold text-emerald-400">{entry.data.result}</div>
            </div>
            <div>
                <div class="text-white/30 text-[10px] uppercase tracking-widest mb-1">ROAS</div>
                <div class="text-3xl font-bold text-white">{entry.data.roas}</div>
            </div>
        </div>
      </header>

      <article class="prose prose-invert prose-emerald max-w-none 
        prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-12
        prose-p:text-white/60 prose-p:leading-relaxed
        prose-li:text-white/60 prose-img:rounded-3xl prose-img:border prose-img:border-white/10">
        <Content />
      </article>
    </div>
  </main>
</Layout>
